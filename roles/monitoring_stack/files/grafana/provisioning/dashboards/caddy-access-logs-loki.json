{
  "uid": "caddy-access-loki-prod",
  "title": "Caddy Access Logs (Production)",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["production", "caddy", "loki", "logs"],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"caddy\"}, host)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      },
      {
        "name": "site",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"caddy\", host=~\"$host\"}, site)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests (logs/min)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"caddy\", host=~\"$host\", site=~\"$site\"}[1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Errors 4xx/5xx (logs/min)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate({job=\"caddy\", host=~\"$host\", site=~\"$site\"} | json | status >= 400 [1m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (rate({job=\"caddy\", host=~\"$host\", site=~\"$site\"} | json | status != \"\" [1m]))"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Latest Caddy Access Logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 14 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"caddy\", host=~\"$host\", site=~\"$site\"} | json"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    }
  ]
}
