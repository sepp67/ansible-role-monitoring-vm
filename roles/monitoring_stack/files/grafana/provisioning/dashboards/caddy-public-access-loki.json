{
  "uid": "caddy-public-access-prod",
  "title": "Caddy Public Access Logs (Production)",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["production", "caddy", "loki", "access"],
  "templating": {
    "list": [
      {
        "name": "host",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=\"caddy\"}, host)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests per Domain (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (domain) (count_over_time({job=\"caddy\", host=~\"$host\"} | json | domain=`{{.request.host}}` [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP Status Codes (5m)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (status) (count_over_time({job=\"caddy\", host=~\"$host\"} | json [5m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Top Public IPs (5m)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (remote_ip) (count_over_time({job=\"caddy\", host=~\"$host\"} | json | remote_ip !~ \"^(127\\\\.0\\\\.0\\\\.1|10\\\\.|192\\\\.168\\\\.|172\\\\.(1[6-9]|2[0-9]|3[0-1]))\" [5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Top Requested Domains (5m)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (host_label) (count_over_time({job=\"caddy\", host=~\"$host\"} | json | label_format host_label=\"{{.request.host}}\" [5m])))"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "logs",
      "title": "Latest Public Access Logs",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 10 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"caddy\", host=~\"$host\"} | json | remote_ip !~ \"^(127\\\\.0\\\\.0\\\\.1|10\\\\.|192\\\\.168\\\\.|172\\\\.(1[6-9]|2[0-9]|3[0-1]))\" | line_format \"ts={{.ts}} ip={{.request.remote_ip}} domain={{.request.host}} method={{.request.method}} status={{.status}} uri={{.request.uri}}\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": false
      }
    },
    {
      "type": "table",
      "title": "Public Requests Table",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 10 },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"caddy\", host=~\"$host\"} | json | remote_ip !~ \"^(127\\\\.0\\\\.0\\\\.1|10\\\\.|192\\\\.168\\\\.|172\\\\.(1[6-9]|2[0-9]|3[0-1]))\" | line_format \"ts={{.ts}} ip={{.request.remote_ip}} domain={{.request.host}} status={{.status}} method={{.request.method}} uri={{.request.uri}}\""
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": {
            "format": "kvp",
            "source": "Line"
          }
        }
      ],
      "options": {
        "showHeader": true,
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    }
  ]
}
