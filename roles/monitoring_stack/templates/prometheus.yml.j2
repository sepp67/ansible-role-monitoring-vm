global:
  scrape_interval: 15s
  evaluation_interval: 15s

rule_files:
  - /etc/prometheus/alerts.yml

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets:
          - "prometheus:9090"

  - job_name: blackbox
    metrics_path: /probe
    params:
      module: [http_2xx]
    file_sd_configs:
      - files:
          - /etc/prometheus/file_sd/blackbox_targets/*.yml
        refresh_interval: 30s
    relabel_configs:
      - source_labels: [__address__]
        target_label: __tmp_target
      - source_labels: [__tmp_target]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: blackbox:9115

  - job_name: node
    file_sd_configs:
      - files:
          - /etc/prometheus/file_sd/node_targets/*.yml
        refresh_interval: 30s

{% if monitoring_extra_scrape_configs | length > 0 %}
{{ monitoring_extra_scrape_configs | to_nice_yaml(indent=2) }}
{% endif %}

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "alertmanager:9093"