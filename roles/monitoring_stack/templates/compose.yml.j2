version: "3.9"

services:
  prometheus:
    image: prom/prometheus:latest
    container_name: prometheus
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.retention.time={{ monitoring_prometheus_retention_time }}
      - --storage.tsdb.retention.size={{ monitoring_prometheus_retention_size }}
      - --web.enable-lifecycle
    ports:
      - "{{ monitoring_prometheus_port }}:9090"
    volumes:
      - {{ monitoring_stack_install_dir }}/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - {{ monitoring_stack_install_dir }}/prometheus/alerts.yml:/etc/prometheus/alerts.yml:ro
      - {{ monitoring_prometheus_file_sd_root }}:/etc/prometheus/file_sd
      - prometheus-data:/prometheus
    depends_on:
      - blackbox
      - alertmanager

  grafana:
    image: grafana/grafana:latest
    container_name: grafana
    restart: unless-stopped
    env_file:
      - {{ monitoring_stack_install_dir }}/grafana/grafana.env
    ports:
      - "{{ monitoring_grafana_port }}:3000"
    volumes:
      - grafana-data:/var/lib/grafana
      - {{ monitoring_stack_install_dir }}/grafana/provisioning:/etc/grafana/provisioning:ro
      - {{ monitoring_stack_install_dir }}/grafana/dashboards:/var/lib/grafana/dashboards:ro
    depends_on:
      - prometheus
      - loki

  loki:
    image: grafana/loki:latest
    container_name: loki
    restart: unless-stopped
    command: -config.file=/etc/loki/local-config.yaml
    ports:
      - "{{ monitoring_loki_port }}:3100"
    volumes:
      - {{ monitoring_stack_install_dir }}/loki/loki-config.yml:/etc/loki/local-config.yaml:ro
      - loki-data:/loki

  alertmanager:
    image: prom/alertmanager:latest
    container_name: alertmanager
    restart: unless-stopped
    command:
      - --config.file=/etc/alertmanager/alertmanager.yml
    ports:
      - "{{ monitoring_alertmanager_port }}:9093"
    volumes:
      - {{ monitoring_stack_install_dir }}/alertmanager/alertmanager.yml:/etc/alertmanager/alertmanager.yml:ro

  blackbox:
    image: prom/blackbox-exporter:latest
    container_name: blackbox
    restart: unless-stopped
    command:
      - --config.file=/etc/blackbox_exporter/config.yml
    ports:
      - "{{ monitoring_blackbox_port }}:9115"
    volumes:
      - {{ monitoring_stack_install_dir }}/blackbox/blackbox.yml:/etc/blackbox_exporter/config.yml:ro

  pve-exporter:
    image: {{ monitoring_pve_exporter_image }}
    container_name: pve-exporter
    restart: unless-stopped
    command:
      - --config.file
      - /etc/prometheus/pve.yml
    ports:
      - "127.0.0.1:{{ monitoring_pve_exporter_port }}:9221"
    volumes:
      - {{ monitoring_stack_install_dir }}/pve-exporter/pve.yml:/etc/prometheus/pve.yml:ro  
  
volumes:
  prometheus-data:
  grafana-data:
  loki-data:
